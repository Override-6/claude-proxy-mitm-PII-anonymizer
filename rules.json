{
  "exempt_words": [
    "claude",
    "anthropic",
    "haiku",
    "sonnet",
    "opus",
    "google"
  ],
  "anxiety_watchlist": [
    ".*"
  ],
  "blocked_urls": [
    {
      "_comment": "claude.ai — MCP tool calls (must use local MCP servers instead)",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/mcp/servers/[^/]+/tools/call"
    },
    {
      "_comment": "claude.ai metrics",
      "url_pattern": "https://api\\.anthropic\\.com/api/event_logging/.*"
    },
    {
      "_comment": "claude.ai metrics",
      "url_pattern": "https://statsig\\.anthropic\\.com/.*"
    },
    {
      "_comment": "claude.ai — remote integrations bridge (server-side tool execution, e.g. Gmail, Google Drive)",
      "url_pattern": "https://bridge\\.claudeusercontent\\.com/.*"
    },
    {
      "_comment": "datadog metrics",
      "url_pattern": "https://.*\\.datadoghq\\.com/.*"
    },
    {
      "_comment": "sentry (error loggings and telemetry management)",
      "url_pattern": "https://sentry\\.io/.*"
    }
  ],
  "request_rules": [
    {
      "_comment": "Messages API — create & count_tokens (api + a-api, v1)",
      "url_pattern": "https://(api|a-api)\\.anthropic\\.com/v1/messages(/count_tokens)?",
      "sensitive_fields": [
        ".system[1:][].text",
        ".messages[].content",
        ".tools[]"
      ]
    },
    {
      "_comment": "Messages Batches API (api + a-api, v1)",
      "url_pattern": "https://(api|a-api)\\.anthropic\\.com/v1/messages/batches",
      "sensitive_fields": [
        ".system[1:][].text",
        ".requests[].custom_id",
        ".requests[].params.messages[].content",
        ".requests[].params.messages[].content[].text",
        ".requests[].params.messages[].content[].title",
        ".requests[].params.messages[].content[].context",
        ".requests[].params.messages[].content[].content"
      ]
    },
    {
      "_comment": "Legacy Completions API (api + a-api, v1)",
      "url_pattern": "https://(api|a-api)\\.anthropic\\.com/v1/complete",
      "sensitive_fields": [
        ".system[1:][].text",
        ".prompt"
      ]
    },
    {
      "_comment": "Files API upload — multipart (api + a-api, v1)",
      "url_pattern": "https://(api|a-api)\\.anthropic\\.com/v1/files",
      "sensitive_fields": true
    },
    {
      "_comment": "Skills API — create & update versions (api + a-api, v1)",
      "url_pattern": "https://(api|a-api)\\.anthropic\\.com/v1/skills(/[^/]+/versions)?",
      "sensitive_fields": true
    },
    {
      "_comment": "Admin — invite member (api + a-api, v1)",
      "url_pattern": "https://(api|a-api)\\.anthropic\\.com/v1/organizations/invites",
      "sensitive_fields": [
        ".email"
      ]
    },
    {
      "_comment": "Admin — create/update workspace (api + a-api, v1)",
      "url_pattern": "https://(api|a-api)\\.anthropic\\.com/v1/organizations/workspaces(/[^/]+)?",
      "sensitive_fields": [
        ".name",
        ".description"
      ]
    },
    {
      "_comment": "Admin — rename API key (api + a-api, v1)",
      "url_pattern": "https://(api|a-api)\\.anthropic\\.com/v1/organizations/api_keys/[^/]+",
      "sensitive_fields": [
        ".name"
      ]
    },
    {
      "_comment": "claude.ai — MCP tool call inputs",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/mcp/servers/[^/]+/tools/call",
      "sensitive_fields": [
        ".arguments"
      ]
    },
    {
      "_comment": "claude.ai — chat completion / retry / continue",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/chat_conversations/[^/]+/(completion|retry_completion|continue|retry)",
      "sensitive_fields": [
        ".prompt",
        ".system[1:][].text",
        ".attachments[].extracted_content",
        ".attachments[].file_name"
      ]
    },
    {
      "_comment": "claude.ai — session title generation",
      "url_pattern": "https://claude\\.ai/api/.*/(generate_session_)?title",
      "sensitive_fields": [
        ".first_session_message",
        ".message_content"
      ]
    },
    {
      "_comment": "claude.ai — session title generation",
      "url_pattern": "https://claude\\.ai/api/.*/generate_session_title",
      "sensitive_fields": [
        ".first_session_message"
      ]
    },
    {
      "_comment": "claude.ai — create or update chat conversation",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/chat_conversations(/[^/]+)?",
      "sensitive_fields": [
        ".name",
        ".title",
        ".summary"
      ]
    },
    {
      "_comment": "claude.ai — rename chat (legacy)",
      "url_pattern": "https://claude\\.ai/api/rename_chat",
      "sensitive_fields": [
        ".title"
      ]
    },
    {
      "_comment": "claude.ai — append message (legacy)",
      "url_pattern": "https://claude\\.ai/api/append_message",
      "sensitive_fields": [
        ".text",
        ".system[1:][].text",
        ".attachments[].extracted_content",
        ".attachments[].file_name",
        ".completion.prompt"
      ]
    },
    {
      "_comment": "claude.ai — conversation feedback",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/chat_conversations/[^/]+/feedback",
      "sensitive_fields": [
        ".comment"
      ]
    },
    {
      "_comment": "claude.ai — any file upload or document conversion endpoint (multipart), at any path depth",
      "url_pattern": "https://claude\\.ai/api/.+/(upload(-file)?|convert_document)",
      "sensitive_fields": true
    },
    {
      "_comment": "claude.ai — account / profile updates",
      "url_pattern": "https://claude\\.ai/api/(organizations/[^/]+/)?(account|settings|profile)",
      "sensitive_fields": [
        ".name",
        ".full_name",
        ".email",
        ".display_name"
      ]
    },
    {
      "_comment": "claude.ai — project prompt templates, knowledge, and docs",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/projects/[^/]+/(prompt_templates|docs|knowledge|prompt)",
      "sensitive_fields": [
        ".title",
        ".content",
        ".prompt"
      ]
    },
    {
      "_comment": "claude.ai — create/update project",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/projects(/[^/]+)?",
      "sensitive_fields": [
        ".name",
        ".description"
      ]
    },
    {
      "_comment": "claude.ai — search conversations",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/chat_conversations/search",
      "sensitive_fields": [
        ".query"
      ]
    }
  ],
  "mcp_rules": [
    {
      "_comment": "google_workspace_mcp reverse proxy — deanon args from Claude, re-anon tool results back to Claude. sensitive_fields:true covers every string in the body.",
      "url_pattern": "http://[^/]+:8000/.*",
      "sensitive_fields": true
    }
  ],
  "response_rules": [
    {
      "_comment": "Messages API response (api + a-api, v1) — non-streaming + SSE",
      "url_pattern": "https://(api|a-api)\\.anthropic\\.com/v1/messages",
      "sensitive_fields": [
        ".content[].text",
        ".content[].thinking",
        ".content[].input"
      ],
      "sse_fields": [
        ".delta.text",
        ".delta.thinking",
        ".delta.partial_json",
        ".content_block.text"
      ]
    },
    {
      "_comment": "Legacy Completions API response (api + a-api, v1) — non-streaming + SSE",
      "url_pattern": "https://(api|a-api)\\.anthropic\\.com/v1/complete",
      "sensitive_fields": [
        ".completion"
      ],
      "sse_fields": [
        ".completion"
      ]
    },
    {
      "_comment": "Batch results — each result contains a message response",
      "url_pattern": "https://(api|a-api)\\.anthropic\\.com/v1/messages/batches/[^/]+/results",
      "sensitive_fields": [
        ".result.message.content[].text",
        ".result.message.content[].thinking",
        ".result.message.content[].input"
      ]
    },
    {
      "_comment": "claude.ai — chat completion response (non-streaming + SSE)",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/chat_conversations/[^/]+/(completion|retry_completion|continue|retry)",
      "sensitive_fields": [
        ".completion",
        ".text",
        ".content[].text",
        ".content[].thinking"
      ],
      "sse_fields": [
        ".completion",
        ".delta.text",
        ".delta.thinking",
        ".delta.partial_json",
        ".content_block.text"
      ]
    },
    {
      "_comment": "claude.ai — single conversation retrieval (messages, title, etc.)",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/chat_conversations/[^/]+",
      "sensitive_fields": [
        ".name",
        ".title",
        ".summary",
        ".chat_messages[].text",
        ".chat_messages[].content[].text",
        ".chat_messages[].attachments[].extracted_content",
        ".chat_messages[].attachments[].file_name"
      ]
    },
    {
      "_comment": "claude.ai — conversation list",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/chat_conversations",
      "sensitive_fields": [
        ".[].name",
        ".[].title",
        ".[].summary"
      ]
    },
    {
      "_comment": "claude.ai — search results",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/chat_conversations/search",
      "sensitive_fields": [
        ".[].name",
        ".[].title",
        ".[].summary",
        ".[].chat_messages[].text"
      ]
    },
    {
      "_comment": "claude.ai — account / profile retrieval",
      "url_pattern": "https://claude\\.ai/api/(organizations/[^/]+/)?(account|settings|profile)",
      "sensitive_fields": [
        ".name",
        ".full_name",
        ".email",
        ".display_name"
      ]
    },
    {
      "_comment": "claude.ai — project details",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/projects/[^/]+",
      "sensitive_fields": [
        ".name",
        ".description"
      ]
    },
    {
      "_comment": "claude.ai — project knowledge / docs listing",
      "url_pattern": "https://claude\\.ai/api/organizations/[^/]+/projects/[^/]+/(prompt_templates|docs|knowledge)",
      "sensitive_fields": [
        ".[].title",
        ".[].content",
        ".[].prompt"
      ]
    }
  ]
}
